{
  "name": "vellum-agent-skill",
  "version": "1.3.0",
  "description": "Vellum Skill for AI Agents \u2014 Payments, trading, and Flaunch token launches on Base",
  "main": "cli.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "vellum": "./bin.js"
  },
  "files": [
    "bin.js",
    "cli.js",
    "install.js",
    "SKILL.md",
    "README.md",
    ".gitattributes"
  ],
  "scripts": {
    "start": "node cli.js",
    "prepare": "chmod 755 bin.js cli.js install.js 2>/dev/null || node -e \"['bin.js','cli.js','install.js'].forEach(f=>{try{require('fs').chmodSync(f,0o755)}catch{}})\"",
    "preinstall": "node -e \"try{require('fs').chmodSync('cli.js',0o755)}catch{}\" 2>/dev/null || true",
    "postinstall": "node install.js || true"
  },
  "keywords": [
    "ai-agent",
    "skill",
    "base",
    "blockchain",
    "payments",
    "x402",
    "trading",
    "vellum",
    "mcp",
    "claude",
    "gemini",
    "uniswap",
    "uniswap-v3",
    "uniswap-v4",
    "switch-agent",
    "multi-agent",
    "flaunch",
    "token-launch",
    "memecoin"
  ],
  "author": "Vellum Finance",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vellum-Finance/vellum-agent-skill.git"
  },
  "homepage": "https://github.com/Vellum-Finance/vellum-agent-skill#readme",
  "dependencies": {
    "commander": "^13.0.0",
    "ethers": "^6.13.0",
    "uuid": "^11.0.0",
    "@flaunch/sdk": "^0.9.16",
    "viem": "^2.31.0"
  }
}
